{
    "manifest_version": 3,
    "name": "YouTube Kapsamlı Analiz",
    "version": "1.0",
    "description": "YouTube videolarını arka planda analiz eder.",
    "icons": {
        "16": "logo/btulogo1616.png",
        "48": "logo/btulogo4848.png",
        "128": "logo/btulogo128128.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "logo/btulogo1616.png",
            "48": "logo/btulogo4848.png",
            "128": "logo/btulogo128128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "http://127.0.0.1:5000/*" 
    ]
}